# =============================================================================
# Data Ingestion Demo — environment variables
# =============================================================================
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# All scripts auto-load `.env` via python-dotenv at import time, so a bare
# `python src/...` invocation picks these up without `source`/`export`.
# =============================================================================

# -----------------------------------------------------------------------------
# MongoDB connection (read by all scripts; --uri / --database CLI flags override)
# Use an Atlas SRV connection string for Atlas Search / Vector Search features.
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017
FHIR_DB=fhir_poc

# -----------------------------------------------------------------------------
# Voyage AI — embeddings for src/fhir_vector_search.py (voyage-4, 1024-dim)
# Get a key at https://dash.voyageai.com/
# -----------------------------------------------------------------------------
VOYAGE_API_KEY=

# -----------------------------------------------------------------------------
# Grove gateway — OpenAI Responses API (gpt-5.5) for RAG `ask` command
# Endpoint: https://grove-gateway-prod.azure-api.net/grove-foundry-prod/openai/v1/responses
# -----------------------------------------------------------------------------
GROVE_API_KEY=
